{
  "name": "http-server",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --env-file=../../.env.local src/index.ts",
    "start": "bun --env-file=../../.env.local ./dist/index.js",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "@repo/db": "*",
    "@repo/env": "*"
  }
}
